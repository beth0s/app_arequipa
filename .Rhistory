library(shiny)
library(shinydashboard)
library(tidyverse)
library(plotly)
library(DT)
library(leaflet)
# Función para cargar o crear datos de prueba
cargar_datos <- function() {
if(file.exists("data/encuesta_raw.csv")) {
datos <- read.csv("data/encuesta_raw.csv", stringsAsFactors = FALSE)
} else {
set.seed(2026)
n <- 200  # Muestra pequeña para prueba
distritos <- c("Alto Selva Alegre", "Arequipa Cercado", "Cayma", "Cerro Colorado",
"José Luis Bustamante y Rivero", "Mariano Melgar", "La Joya",
"Miraflores", "Paucarpata", "Sachaca", "Socabaya", "Yanahuara", "Yura")
candidatos <- c("Rafael López Aliaga", "Keiko Fujimori", "Alfonso López Chau",
"Carlos Álvarez", "Wolfgang Grozo", "César Acuña",
"Roberto Sánchez", "Yonhy Lescano", "Otro", "Voto blanco",
"Voto nulo", "No sabe")
datos <- data.frame(
id = 1:n,
distrito = sample(distritos, n, replace = TRUE),
sexo = sample(c("Hombre", "Mujer"), n, replace = TRUE),
edad_rango = sample(c("18-24", "25-34", "35-44", "45-54", "55-70"), n, replace = TRUE),
nse = sample(c("A/B", "C", "D/E"), n, replace = TRUE),
voto_presidente = sample(candidatos, n, replace = TRUE),
voto_diputado = sample(c("Ahora Nación", "País para Todos", "Fuerza Popular",
"Renovación Popular", "No sabe"), n, replace = TRUE),
voto_senado = sample(c("Ahora Nación", "País para Todos", "Fuerza Popular",
"Renovación Popular", "No sabe"), n, replace = TRUE),
peso = 1,
stringsAsFactors = FALSE
)
dir.create("data", showWarnings = FALSE)
write.csv(datos, "data/encuesta_raw.csv", row.names = FALSE)
}
return(datos)
}
# Función simplificada para preparar datos de gráficos
preparar_grafico <- function(df, variable) {
# Calcular porcentajes
res <- df %>%
group_by(!!sym(variable)) %>%
summarise(
porcentaje = sum(peso) / sum(df$peso) * 100,
.groups = "drop"
) %>%
arrange(desc(porcentaje))
# Identificar "No sabe" y "Otros"
otros <- res %>% filter(!(!!sym(variable) %in% c("No sabe", "Otros"))) %>% slice_tail(n = max(0, nrow(.) - 7))
otros_pct <- if(nrow(otros) > 0) sum(otros$porcentaje) else 0
# Top candidatos (hasta 8)
top <- res %>% filter(!(!!sym(variable) %in% c("No sabe", "Otros"))) %>% slice_head(n = 7)
# Crear dataframe para gráfico
datos_grafico <- top %>%
select(categoria = !!sym(variable), porcentaje)
if(otros_pct > 0) {
datos_grafico <- rbind(datos_grafico, data.frame(categoria = "Otros", porcentaje = otros_pct))
}
# Agregar No sabe si existe
ns <- res %>% filter(!!sym(variable) == "No sabe")
if(nrow(ns) > 0) {
datos_grafico <- rbind(datos_grafico, data.frame(categoria = "No sabe", porcentaje = ns$porcentaje[1]))
} else {
datos_grafico <- rbind(datos_grafico, data.frame(categoria = "No sabe", porcentaje = 0))
}
# Agregar etiquetas
datos_grafico$texto <- paste0(round(datos_grafico$porcentaje, 1), "%")
datos_grafico$categoria <- factor(datos_grafico$categoria, levels = rev(datos_grafico$categoria))
return(datos_grafico)
}
datos <- cargar_datos()
ui <- dashboardPage(
dashboardHeader(title = "Encuesta Electoral Arequipa 2026"),
dashboardSidebar(
sidebarMenu(
menuItem("Inicio", tabName = "inicio", icon = icon("home")),
menuItem("Intención de voto", tabName = "voto", icon = icon("vote-yea")),
menuItem("Análisis demográfico", tabName = "demografico", icon = icon("users")),
menuItem("Ficha técnica", tabName = "ficha", icon = icon("file-alt"))
),
hr(),
h4("Filtros", style = "text-align: center;"),
selectInput("filtro_distrito", "Distrito:",
choices = c("TODOS", sort(unique(datos$distrito))),
selected = "TODOS"),
selectInput("filtro_sexo", "Sexo:",
choices = c("TODOS", "Hombre", "Mujer"),
selected = "TODOS"),
hr(),
p(paste("Muestra:", nrow(datos), "entrevistas"),
style = "font-size: 11px; text-align: center;")
),
dashboardBody(
tags$head(
tags$style(HTML("
.content-wrapper, .right-side { background-color: #f4f4f4; }
.small-box { border-radius: 10px; }
.box { border-radius: 10px; }
"))
),
tabItems(
